# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
OWNER_ID=your_telegram_user_id
ADMIN_ID=admin_user_id
OWNER_USERNAME=@your_username

# Bot Settings
UPDATE_CHANNEL=https://t.me/TechTipsCode
SUPPORT_CHANNEL=https://t.me/EliteCodeLab

# Web Hosting (Choose one option)
# Option 1: Manual hostname/domain
HOST_URL=https://yourdomain.com

# Option 2: VPS with port (if not using AUTO_IP)
# HOST_URL=http://203.0.113.42:14000

# Option 3: Auto-detect VPS IP (recommended for VPS)
# Leave HOST_URL empty and set AUTO_IP=true
AUTO_IP=true

# Web Server Port (used by Flask)
# AUTO_IP will use this port automatically
# Default: 5000, Common VPS ports: 5000, 8000, 14000
PORT=14000

# Docker Settings
USE_DOCKER=false
DOCKER_IMAGE=hostingbot

# ==================== RESOURCE LIMITS (for low-spec VPS) ====================
# Defaults below are sized for a small (~1GB RAM) VPS. If you're on a bigger box, raise these;
# if you're still seeing OOM kills / timeouts, lower MAX_RUNNING_SCRIPTS first.

# Max scripts allowed to actually be RUNNING at the same time. Extras queue with a
# "waiting for a running slot" message until one of the running ones stops/crashes.
# This is the main lever for total memory usage: each running bot process (telethon/
# pyrogram/python-telegram-bot etc.) typically uses tens to a couple hundred MB.
MAX_RUNNING_SCRIPTS=3

# Max files allowed to be checking imports/installing packages/compiling at the same time.
# This is throughput, not the memory-heavy part — safe to leave higher than MAX_RUNNING_SCRIPTS.
MAX_CONCURRENT_EXECUTIONS=3

# Per-process memory cap (in MB) enforced via RLIMIT_AS, one per user tier. Keeps a single
# runaway or leaky script from consuming all the VPS's RAM by itself. Set to 0 for unlimited
# (not recommended on a small VPS — this previously defaulted to "unlimited" for the owner
# tier, which is what let testing bots collectively exhaust a 1GB box).
RAM_LIMIT_FREE_MB=250
RAM_LIMIT_PREMIUM_MB=400
RAM_LIMIT_ADMIN_MB=500
RAM_LIMIT_OWNER_MB=500
